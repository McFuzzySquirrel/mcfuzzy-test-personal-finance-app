    "babel-preset-expo": "^55.0.11",
    "detox": "^20.47.0",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-native": "5.0.0",
    "jest": "30.3.0",
    "jest-expo": "55.0.9",
    "typescript": "5.9.3"
  }
